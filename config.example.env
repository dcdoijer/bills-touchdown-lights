# Hue Bridge settings
BTL_HUE_BRIDGE_IP=192.168.1.100
BTL_HUE_API_KEY=your-api-key-here
BTL_HUE_LIGHT_IDS=["1","2","3"]

# Animation settings
BTL_DEFAULT_PATTERN=cycle_together
BTL_ANIMATION_DURATION=30.0
BTL_STEP_DURATION=0.5

# ESPN polling intervals (seconds)
BTL_ESPN_POLL_INTERVAL_LIVE=10
BTL_ESPN_POLL_INTERVAL_PREGAME=60
BTL_ESPN_POLL_INTERVAL_NOGAME=300

# Server
BTL_HOST=0.0.0.0
BTL_PORT=8080
